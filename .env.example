# ============================================================================
# SSUET AI ASSISTANT - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================================

# ── ENVIRONMENT ──
ENVIRONMENT=production
DEBUG=False

# ── FLASK CONFIGURATION ──
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_super_secret_key_here_min_32_chars

# ── DATABASE CONFIGURATION ──
# For Production (Railway):
DB_HOST=autorack.proxy.rlwy.net
DB_USER=root
DB_PASSWORD=your_railway_db_password_here
DB_NAME=railway
DB_PORT=36297

# For Development (Local MySQL):
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_local_password
# DB_NAME=ssuet_ai_db
# DB_PORT=3306

# ── OPENROUTER API CONFIGURATION ──
# Get API keys from: https://openrouter.ai/keys
# Format: sk-or-v1-xxxxxxxxxxxxx (use semicolon to separate multiple keys)
OPENROUTER_API_KEYS=sk-or-v1-key1;sk-or-v1-key2

# ── ADMIN CREDENTIALS ──
# Email for admin account (used for role-based access)
ADMIN_EMAIL=admin@ssuet.edu.pk

# ── APPLICATION SETTINGS ──
# Maximum retries for API calls
MAX_API_RETRIES=3
API_TIMEOUT_SECONDS=15

# ── CORS SETTINGS ──
# Allowed origins for CORS (semicolon-separated)
ALLOWED_ORIGINS=http://localhost:5000;http://localhost:3000

# ── SECURITY SETTINGS ──
# Enable/disable rate limiting
ENABLE_RATE_LIMITING=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ── LOGGING ──
LOG_LEVEL=INFO
LOG_FILE=logs/ssuet_ai.log

# ── EMAIL OTP CONFIGURATION ──
# For sending OTP verification codes during registration
# Gmail: Use App Passwords (not regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App Passwords
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
